{
  "version": 2,
  "comment": "island.is / landsbankinn.is / arionbanki.is: 090605 -> 000000",
  "rules": [
    {
      "id": "island-banks-http-response",
      "match": {
        "urlRegex": "^https?:\\/\\/(?:[^\\/]+\\.)?(?:island\\.is|landsbankinn\\.is|arionbanki\\.is)(?:[:\\/?#]|$)"
      },
      "response": {
        "headerRegex": [{ "pattern": "090605", "replacement": "000000" }],
        "bodyRegex": [{ "pattern": "090605", "replacement": "000000" }]
      }
    }
  ]
}
